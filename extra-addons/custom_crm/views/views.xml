<odoo>
  <data>
    <!--VISTA FORMULARIO-->
    <!--view_namemodule_namemodel_form-->
    <record id="view_custom_crm_visit_form" model="ir.ui.view">
      <field name="name">view.custom.crm.visit.form</field>
      <field name="model">custom_crm.visit</field>
      <field name="arch" type="xml">
        <form string="Visita">
          <sheet>
            <group name="group_top">
              <group name="group_left">
                <field name="costumer"/>
                <field name="date"/>
                <field name="type"/>
            </group>
              <group name="group_right">
              <field name="name"/>
                <field name="done"/>
            </group>

            </group>
          </sheet>
        </form>

      </field>
    </record>
    <!--FIN VISTA FORMULARIO-->



    <!--VISTA TREE-->
    <record id="view_custom_crm_visit_tree" model="ir.ui.view">
      <field name="name">view.custom.crm.visit.tree</field>
      <field name="model">custom_crm.visit</field>
      <field name="arch" type="xml">
        <tree string="">
        <field name="costumer"/>
          <field name="name"/>
          <field name="type"/>
          <field name="date"/>
        </tree>
      </field>
    </record>
    <!--FIN VISTA TREE-->
    <!--ACTION-->
    <record id="action_custom_crm_view" model="ir.actions.act_window">
    <field name="name">Visita</field>
      <field name="type">ir.actions.act_window</field>
       <field name="res_model">custom_crm.visit</field>
      <field name="view_mode">tree,form</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Visitas
        </p>
        <p>
          Clic 'Nuevo' para anadir nuevo elemento
        </p>
      </field>
    </record>
    <!--FIN ACTION-->
  <!--MENU-->
    <!--DEPENDE DEL ACTION-->
  <menuitem id="menu_custom_crm_root" name="Custom CRM" sequence="18"/>
  <menuitem id="menu_custom_crm_category" name="Operaciones" parent="menu_custom_crm_root" sequence="0"/>
  <menuitem id="menu_custom_crm_visit" name="Visitas" parent="menu_custom_crm_category" sequence="0" action="action_custom_crm_view"/>
   <!--FIN MENU-->
  </data>
</odoo>